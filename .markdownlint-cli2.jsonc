{
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD041": false,
    "MD024": { "siblings_only": true },
    "MD026": { "punctuation": ".,;:!" },
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".claude/checkpoints",
    ".claude/compactions",
    ".claude/skills",
    ".agents",
    "context/critics/*/findings.md",
    "context/monitor/alerts.md",
    "demo-output",
    "demo-baselines",
    "site",
    "tmp",
    "local-runs",
    "history",
    "raw-videos",
    "transcripts",
    "research",
    "notes",
  ],
}
