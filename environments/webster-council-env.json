{
  "name": "webster-council-env",
  "config": {
    "type": "cloud",
    "packages": {
      "apt": ["git", "jq"],
      "npm": ["@astrojs/cloudflare"]
    },
    "networking": {
      "type": "limited",
      "allowed_hosts": [
        "api.github.com",
        "github.com",
        "raw.githubusercontent.com",
        "api.anthropic.com",
        "certified.richerhealth.ca",
        "richerhealth.ca"
      ],
      "allow_mcp_servers": true,
      "allow_package_managers": true
    }
  }
}
